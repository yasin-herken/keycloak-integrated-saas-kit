# .env.example - Copy this file to .env and fill in the values

# Project name used for realm naming (e.g., hedef-proje-dev, hedef-proje-prod)
PROJECT_NAME=

# PostgreSQL Configuration
DB_NAME=keycloak
DB_USER=keycloak
DB_PASSWORD=keycloak-admin

# Keycloak Admin Credentials
KEYCLOAK_ADMIN_USER=administrator
KEYCLOAK_ADMIN_PASS=administrator
